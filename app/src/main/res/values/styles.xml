<resources>
    <!-- Base application theme. -->
    <style name="Theme.ToDoList.AppBarOverlay" parent="ThemeOverlay.Material3.ActionBar" />
    <style name="Theme.ToDoList.PopupOverlay" parent="ThemeOverlay.Material3.Light" />

    <!-- Glassmorphism Dialog Theme -->
    <style name="GlassDialogTheme" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.5</item>
    </style>
</resources>
