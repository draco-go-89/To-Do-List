<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Group for layers to handle scaling and centering within 72dp safe zone -->
    <group
        android:translateX="54"
        android:translateY="54">

        <!-- Layer 1: Soft Purple Square (Bottom) -->
        <group
            android:pivotX="0"
            android:pivotY="0"
            android:rotation="15">
            <path
                android:fillColor="#FF9575CD"
                android:pathData="M-20,-20 h40 a4,4 0 0,1 4,4 v40 a4,4 0 0,1 -4,4 h-40 a4,4 0 0,1 -4,-4 v-40 a4,4 0 0,1 4,-4 z" />
        </group>

        <!-- Layer 2: Light Indigo Square (Middle) -->
        <group
            android:pivotX="0"
            android:pivotY="0"
            android:rotation="-8">
            <path
                android:fillColor="#FF7986CB"
                android:pathData="M-20,-20 h40 a4,4 0 0,1 4,4 v40 a4,4 0 0,1 -4,4 h-40 a4,4 0 0,1 -4,-4 v-40 a4,4 0 0,1 4,-4 z" />
        </group>

        <!-- Layer 3: Sky Blue Square (Top) -->
        <group
            android:pivotX="0"
            android:pivotY="0">
            <path
                android:fillColor="#FF4FC3F7"
                android:pathData="M-20,-20 h40 a4,4 0 0,1 4,4 v40 a4,4 0 0,1 -4,4 h-40 a4,4 0 0,1 -4,-4 v-40 a4,4 0 0,1 4,-4 z" />
        </group>

        <!-- Thick, Bold White Checkmark -->
        <path
            android:pathData="M-10,0 l8,8 l18,-18"
            android:strokeWidth="8"
            android:strokeColor="#FFFFFF"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />

    </group>

</vector>
