<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="New Quest"
        android:textAppearance="?attr/textAppearanceHeadlineSmall"
        android:textColor="#333333"
        android:textStyle="bold" />

    <!-- Task Title Section -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Task Title"
        app:boxStrokeColor="#333333"
        app:hintTextColor="#666666">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etTaskTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapSentences"
            android:textColor="#333333" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Columnar Section for Difficulty and Deadline -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <!-- Left Column: Difficulty -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Difficulty"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="#333333" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/cgDifficulty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipEasy"
                    style="@style/Widget.Material3.Chip.Suggestion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="Easy"
                    android:textSize="12sp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMedium"
                    style="@style/Widget.Material3.Chip.Suggestion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Med"
                    android:textSize="12sp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipHard"
                    style="@style/Widget.Material3.Chip.Suggestion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hard"
                    android:textSize="12sp" />
            </com.google.android.material.chip.ChipGroup>
        </LinearLayout>

        <!-- Right Column: Deadline -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Deadline"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="#333333" />

            <Button
                android:id="@+id/btnSetDeadline"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:paddingHorizontal="4dp"
                android:text="Set"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Reminder Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Remind Me Before"
        android:textAppearance="?attr/textAppearanceTitleSmall"
        android:textColor="#333333" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/cgReminder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip5min"
            style="@style/Widget.Material3.Chip.Suggestion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5m"
            android:textSize="11sp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip10min"
            style="@style/Widget.Material3.Chip.Suggestion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10m"
            android:textSize="11sp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip15min"
            style="@style/Widget.Material3.Chip.Suggestion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15m"
            android:textSize="11sp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip30min"
            style="@style/Widget.Material3.Chip.Suggestion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="30m"
            android:textSize="11sp" />
    </com.google.android.material.chip.ChipGroup>

</LinearLayout>
